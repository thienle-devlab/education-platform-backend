# ==========================================
# EDUCATION PLATFORM - COMPREHENSIVE .GITIGNORE
# ==========================================
# Microservices project with Spring Boot, Kafka, PostgreSQL, Docker
# No duplicate patterns - clean and optimized

# ==========================================
# SENSITIVE FILES (CRITICAL - NEVER COMMIT!)
# ==========================================
# Environment variables
.env
.env.local
.env.*.local
**/.env

# Application configs with secrets
application-dev.yml
application-local.yml
application-prod.yml
**/application-local.yml
**/application-dev.yml
**/application-prod.yml
**/application-secrets.yml
**/*-secrets.yml
**/credentials.yml

# Security keys and certificates
**/*.key
**/*.pem
**/*.p12
**/*.jks
**/*.keystore

# ==========================================
# IDE FILES
# ==========================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Eclipse
.project
.classpath
.settings/
.metadata/
bin/
.apt_generated
.factorypath
.springBeans
.sts4-cache
local.properties
.loadpath
.recommenders

# VS Code
.vscode/
*.code-workspace

# NetBeans
nbproject/private/
/nbproject/private/
nbbuild/
/nbbuild/
dist/
/dist/
nbdist/
/nbdist/
.nb-gradle/
/.nb-gradle/

# ==========================================
# BUILD & TARGET DIRECTORIES
# ==========================================
# Maven
target/
!**/src/main/**/target/
!**/src/test/**/target/

# Gradle
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ==========================================
# SPRING BOOT
# ==========================================
HELP.md
.spring-boot-devtools.properties

# ==========================================
# LOGS
# ==========================================
*.log
*.log.*
*.log.gz
logs/
log/

# ==========================================
# DATABASE
# ==========================================
*.db
*.sqlite
*.sqlite3
*.h2.db
*.trace.db

# ==========================================
# OS FILES
# ==========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==========================================
# DOCKER
# ==========================================
docker-compose.override.yml
docker-compose.*.local.yml

# ==========================================
# NODE (if using frontend)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# TEMPORARY & BACKUP FILES
# ==========================================
*.tmp
*.temp
*.cache
*.pid
*.seed
*.pid.lock
*.bak
*.backup
*.old
*.swp
*~
*~.nib

# ==========================================
# PACKAGE FILES
# ==========================================
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Exceptions - allow wrapper JARs
!.mvn/wrapper/maven-wrapper.jar
!gradle-wrapper.jar

# ==========================================
# COMPILED CLASS FILES
# ==========================================
*.class

# ==========================================
# TEST COVERAGE
# ==========================================
*.exec
.sonar/
coverage/
.nyc_output/
